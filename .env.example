# =====================================================================
# Plantilla de variables de entorno. Copia este archivo a ".env" y
# rellena los valores reales. El .env NUNCA se versiona (ver .gitignore).
# =====================================================================

# ---------- copilot/ (agente Python) ----------
OPENAI_API_KEY=
# Modelo por defecto del agente
COPILOT_MODEL=gpt-5-mini

# Conexion del agente a Wash & Ready.
# Opcion A (recomendada): API REST del backend
WASHREADY_API_URL=http://localhost:8080
WASHREADY_API_USER=admin
WASHREADY_API_PASSWORD=
# Opcion B: acceso directo a MySQL con un usuario de SOLO LECTURA
WASHREADY_DB_URL=mysql+pymysql://copilot_ro:CHANGE_ME@localhost:3306/wash_ready_db

# Observabilidad (Langfuse)
LANGFUSE_HOST=http://localhost:3000
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=

# ---------- wash-ready/ (backend Spring Boot) ----------
DB_URL=jdbc:mysql://localhost:3306/wash_ready_db?useSSL=false&allowPublicKeyRetrieval=true&serverTimezone=UTC
DB_USERNAME=wash_ready_user
DB_PASSWORD=
JWT_SECRET=
BOOTSTRAP_ADMIN_USUARIO=admin
BOOTSTRAP_ADMIN_PASSWORD=
MAIL_USERNAME=
MAIL_PASSWORD=

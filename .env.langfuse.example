# =====================================================================
# Secretos LOCALES para el stack de Langfuse (docker-compose.langfuse.yml).
# Copia este archivo a ".env.langfuse" y rellena valores aleatorios reales.
# .env.langfuse NUNCA se versiona (ver .gitignore).
#
# Genera cada valor con, por ejemplo:
#   python -c "import secrets; print(secrets.token_urlsafe(24))"
# ENCRYPTION_KEY debe ser hex de 32 bytes:
#   python -c "import secrets; print(secrets.token_hex(32))"
# =====================================================================

SALT=
ENCRYPTION_KEY=
CLICKHOUSE_PASSWORD=
# OJO: el compose oficial NO interpola POSTGRES_PASSWORD dentro de DATABASE_URL;
# hay que repetir la misma contraseña aqui a mano o falla la autenticacion.
DATABASE_URL=postgresql://postgres:MISMA_PASSWORD_QUE_POSTGRES_PASSWORD@postgres:5432/postgres
# OJO: estas 3 claves S3 son las credenciales con las que langfuse-web/worker
# se autentican contra MinIO -> deben ser IDENTICAS a MINIO_ROOT_PASSWORD,
# no valores random independientes (si no, falla la subida con SignatureDoesNotMatch).
LANGFUSE_S3_EVENT_UPLOAD_SECRET_ACCESS_KEY=MISMA_PASSWORD_QUE_MINIO_ROOT_PASSWORD
LANGFUSE_S3_MEDIA_UPLOAD_SECRET_ACCESS_KEY=MISMA_PASSWORD_QUE_MINIO_ROOT_PASSWORD
LANGFUSE_S3_BATCH_EXPORT_SECRET_ACCESS_KEY=MISMA_PASSWORD_QUE_MINIO_ROOT_PASSWORD
REDIS_AUTH=
NEXTAUTH_SECRET=
MINIO_ROOT_PASSWORD=
POSTGRES_PASSWORD=

# Auto-provisiona organizacion/proyecto/usuario/claves API al primer arranque
# (evita tener que crearlos a mano desde la UI de Langfuse).
LANGFUSE_INIT_ORG_ID=washready
LANGFUSE_INIT_ORG_NAME=Wash and Ready
LANGFUSE_INIT_PROJECT_ID=washready-copilot
LANGFUSE_INIT_PROJECT_NAME=washready-copilot
LANGFUSE_INIT_PROJECT_PUBLIC_KEY=pk-lf-
LANGFUSE_INIT_PROJECT_SECRET_KEY=sk-lf-
LANGFUSE_INIT_USER_EMAIL=admin@washready.local
LANGFUSE_INIT_USER_NAME=Admin
LANGFUSE_INIT_USER_PASSWORD=
